<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#050916"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.78"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/ld_cell_if10"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#090E1C">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="3dp"
                android:layout_marginTop="1dp"
                android:text="↗"
                android:textColor="#8A96AD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/ld_if10"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center|end"
                android:paddingEnd="3dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="31sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/ld_cell_avg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="2dp"
            android:background="#090E1C">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="3dp"
                android:layout_marginTop="1dp"
                android:text="Ø"
                android:textColor="#8A96AD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/ld_avg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center|end"
                android:paddingEnd="3dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/ld_cell_speed"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.22"
        android:layout_marginStart="2dp"
        android:background="#090E1C">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="⌁"
            android:textColor="#8A96AD"
            android:textSize="16sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/ld_speed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|end"
            android:paddingEnd="4dp"
            android:text="0.0"
            android:textColor="#FFFFFF"
            android:textSize="46sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/ld_cell_power"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.08"
        android:layout_marginStart="2dp"
        android:background="#090E1C">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="⚡"
            android:textColor="#8A96AD"
            android:textSize="15sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/ld_power"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|end"
            android:paddingEnd="4dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.74"
        android:layout_marginStart="2dp"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/ld_cell_hr"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#090E1C">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="3dp"
                android:layout_marginTop="1dp"
                android:text="♥"
                android:textColor="#8A96AD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/ld_hr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center|end"
                android:paddingEnd="3dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/ld_cell_cad"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="2dp"
            android:background="#090E1C">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="3dp"
                android:layout_marginTop="1dp"
                android:text="↻"
                android:textColor="#8A96AD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/ld_cad"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center|end"
                android:paddingEnd="3dp"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
