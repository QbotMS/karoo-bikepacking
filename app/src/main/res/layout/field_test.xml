<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1424"
    android:padding="6dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tv_speed"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold"
            android:text="0.0 km/h"/>
        <TextView android:id="@+id/tv_power"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold"
            android:gravity="end" android:text="0W --"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/tv_hr"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8a96ad" android:textSize="13sp" android:text="HR --"/>
        <TextView android:id="@+id/tv_cadence"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8a96ad" android:textSize="13sp"
            android:gravity="center" android:text="Cad 0"/>
        <TextView android:id="@+id/tv_grade"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF" android:textSize="13sp"
            android:gravity="end" android:text="+0.0%"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/tv_distance"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8a96ad" android:textSize="13sp" android:text="Dist 0.0"/>
        <TextView android:id="@+id/tv_remaining"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8a96ad" android:textSize="13sp"
            android:gravity="center" android:text="Poz --"/>
        <TextView android:id="@+id/tv_smart_avg"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8a96ad" android:textSize="13sp"
            android:gravity="end" android:text="avg 0.0"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp">
        <TextView android:id="@+id/tv_eta"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
            android:text="ETA --:--"/>
        <TextView android:id="@+id/tv_required"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
            android:gravity="end" android:text="→ --"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_warning"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#fda4a4" android:textSize="11sp"
        android:layout_marginTop="2dp" android:text=""/>

</LinearLayout>